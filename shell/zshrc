#!/usr/bin/env zsh
# ~/dotfiles/shell/zshrc — sourced by ~/.zshrc on interactive shell start.
# Tool integrations (starship, fzf, atuin, zoxide, direnv, mise, zsh
# plugins) live in ~/dotfiles/shell/init.sh, sourced via ~/.zshrc.local
# at the bottom of this file. This file is the SHELL BASE: PATH, history,
# completion, options, keybindings.

# =============================================================================
# PATH — typeset -U dedups, path/PATH stay synced
# Only what install.sh actually populates: ~/.local/bin (gh_install target).
# Cargo/bun/etc removed — we don't ship them; user can add per-machine in
# ~/.zshrc.local if they install Rust or Bun later.
# =============================================================================
typeset -U path PATH
path=(
    "$HOME/.local/bin"
    $path
)

# Homebrew on macOS — sets PATH, MANPATH, HOMEBREW_*
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# =============================================================================
# Editor — modern non-modal CLI editor (no vim).
# Preference: micro (Ctrl+S like every other app) → nano → vi (POSIX last
# resort). Override per-machine in ~/.zshrc.local if you want something else.
# =============================================================================
if command -v micro &>/dev/null; then
    export EDITOR='micro' VISUAL='micro'
elif command -v nano &>/dev/null; then
    export EDITOR='nano' VISUAL='nano'
else
    export EDITOR='vi' VISUAL='vi'
fi

# =============================================================================
# History — large, deduplicated, shared between sessions
# HISTSIZE=50000 is community consensus for "big enough you almost never
# lose a command". atuin reads from $HISTFILE for its initial import.
# =============================================================================
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=50000
export SAVEHIST=50000
setopt EXTENDED_HISTORY          # ':<start>:<elapsed>;<command>' format
setopt INC_APPEND_HISTORY        # Append immediately, not on shell exit
setopt SHARE_HISTORY             # Share across all running sessions
setopt HIST_EXPIRE_DUPS_FIRST    # Trim duplicates first when over HISTSIZE
setopt HIST_IGNORE_DUPS          # Don't record event matching previous
setopt HIST_IGNORE_ALL_DUPS      # Drop older duplicates
setopt HIST_FIND_NO_DUPS         # Skip dupes during search
setopt HIST_IGNORE_SPACE         # Lines starting with space aren't recorded
setopt HIST_SAVE_NO_DUPS         # Don't write dupes to file
setopt HIST_VERIFY               # !! and ^ expansion shows command first
setopt HIST_REDUCE_BLANKS        # Strip extraneous whitespace

# =============================================================================
# zsh options — modern defaults
# Sourced from: 'man zshoptions' + Apple's /etc/zshrc + community surveys.
# =============================================================================
setopt AUTO_CD               # `dirname` w/o `cd` works
setopt EXTENDED_GLOB         # ^, ~, # special chars in globs
setopt GLOB_DOTS             # * matches dotfiles too
setopt NUMERIC_GLOB_SORT     # foo2 before foo10
setopt INTERACTIVE_COMMENTS  # # at REPL is a comment
setopt AUTO_PUSHD            # cd auto-pushes to dirstack
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt COMPLETE_IN_WORD      # Tab-complete from middle of word
setopt ALWAYS_TO_END         # Move cursor to end after completion
setopt NO_BEEP               # No terminal bell
setopt PROMPT_SUBST          # Allow $vars and `cmd` in prompt (starship needs this)

# WORDCHARS — Ctrl-W kills one path component, not the whole path.
# Default removes /, so 'foo/bar/baz' Ctrl-W deletes 'baz', then 'bar', etc.
WORDCHARS='*?_-.[]~&;!#$%^(){}<>'

# =============================================================================
# Keybindings — emacs mode (the zsh default; explicit so override-proof)
# Modern shells expect emacs (paste-then-edit, arrow keys move cursor freely).
# Vi mode is opt-in; we don't want it.
# =============================================================================
bindkey -e
# KEYTIMEOUT NOT set to 1 — 10ms breaks multi-byte arrow key sequences (^[[A
# etc. arrive as separate bytes; at 10ms zsh sees only the ESC and discards
# the rest, making up/down arrows unresponsive). Default 40 (400ms) is fine
# in emacs mode; only matters for vi-mode ESC→command-mode snappiness.

# Up/Down arrow → prefix-match history search.
# Without anything typed: walks history line-by-line (default behavior).
# With prefix typed: only cycles through history entries that START with
# what's already on the line. Much more useful than naive history walk.
# Bindings cover both regular ANSI sequences AND tput sequences (some terms).
bindkey '^[[A' history-search-backward    # Up arrow (xterm/most)
bindkey '^[[B' history-search-forward     # Down arrow (xterm/most)
bindkey '^[OA' history-search-backward    # Up arrow (some terms in app mode)
bindkey '^[OB' history-search-forward     # Down arrow (some terms in app mode)

# =============================================================================
# Completion — zsh's built-in compsys
# Modern best-practice from prezto/zim communities.
# =============================================================================
# Cache compinit results to ~/.cache/zsh/zcompdump (faster shell startup)
ZCOMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-$ZSH_VERSION"
mkdir -p "${ZCOMPDUMP:h}"

# Add zsh-completions (cloned by install.sh) to fpath BEFORE compinit
ZSH_PLUGIN_DIR="$HOME/.local/share/zsh-plugins"
[[ -d "$ZSH_PLUGIN_DIR/zsh-completions/src" ]] && \
    fpath=("$ZSH_PLUGIN_DIR/zsh-completions/src" $fpath)

autoload -Uz compinit
# -d: custom dump file location (faster than the default ~/.zcompdump rebuild)
compinit -d "$ZCOMPDUMP"

# Style completions — case-insensitive, partial match, substring match,
# colored, menu-select, cached.
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
zstyle ':completion:*' verbose yes
zstyle ':completion:*:descriptions' format '%B%F{yellow}%d%f%b'
zstyle ':completion:*:warnings' format '%B%F{red}No matches for: %d%f%b'

# =============================================================================
# Pager / man — colored, modern less defaults
# =============================================================================
export LESS='-R -F -X -i -M -j5'   # raw colors, no-clobber, smart-case, status, scrollback
export PAGER='less'
# If bat is installed, use it for man pages (syntax-highlighted)
if command -v bat &>/dev/null; then
    export MANPAGER="sh -c 'col -bx | bat --language man --plain --paging=always'"
else
    export MANPAGER='less -R'
fi

# =============================================================================
# Source ~/.zshrc.local — wires in shell/init.sh + shell/aliases.sh + any
# machine-local additions (atuin sync creds, work-only env vars, etc.)
# =============================================================================
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# =============================================================================
# Step 7 trigger: deploy IDE user settings on first interactive shell after
# VS Code / Cursor's SSH server provisions its User dir. install.sh's Step 7
# can't do this because Coder runs install.sh before any IDE has connected,
# so the dirs don't exist yet at install time. Sentinel keeps the cost at
# two stat()s per shell after the first successful merge.
# =============================================================================
for _srv in "$HOME/.vscode-server/data/User" "$HOME/.cursor-server/data/User"; do
    [[ -d "$_srv" ]] || continue
    [[ -f "$_srv/.dotfiles-merged" ]] && continue
    if [[ -f "$HOME/dotfiles/install.sh" ]]; then
        bash "$HOME/dotfiles/install.sh" settings >/dev/null 2>&1 && touch "$_srv/.dotfiles-merged"
    fi
done
unset _srv
