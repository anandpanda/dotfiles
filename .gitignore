# Never commit credentials or runtime state
.credentials.json
*.credentials*
*.token

# OS noise
.DS_Store
Thumbs.db

# Editor noise
.vscode/
.idea/
*.swp

# Plans are work-tied / project-specific — never sync across machines
claude/plans/

# Memory entries are personal preferences only — keep behavioral ones in repo,
# never commit project_*.md or work-specific findings.
# Project-specific memory (machine/work-only):
claude/memory/project_*.md

# Claude Code local state — auto-generated per machine. The .local.json
# convention is "do not commit" (e.g. enabled MCP servers, session state).
**/.claude/settings.local.json
**/.claude/.session-cache.json
**/.claude/.mcp-needs-auth-cache.json
**/.claude/projects/
**/.claude/sessions/
**/.claude/cache/
**/.claude/scheduled_tasks.lock
**/.claude/*.lock

# Backups created by install.sh / link-here.sh (target-side, but defensive
# in case any land inside the repo)
*.backup.[0-9]*
